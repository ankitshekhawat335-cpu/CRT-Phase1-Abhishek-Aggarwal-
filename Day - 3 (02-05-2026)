//Program 11 -- CountDown Timer

#include <iostream>
#include <unistd.h>  // for sleep()
using namespace std;

int main() {
    int time;

    cout << "Enter countdown time (in seconds): ";
    cin >> time;

    while (time > 0) {
        cout << "Time left: " << time << " seconds" << endl;
        sleep(1);  // wait for 1 second
        time--;
    }

    cout << "Time's up!" << endl;

    return 0;
}


//  Program 12 -- WATER JAR FILLER 
//  Keep adding water until 500ml is reached

#include <iostream>
using namespace std;

int main() {
    int currentWater = 0;
    int add;
    while(currentWater < 500){
        cout << "Glass has " << currentWater << "ml. How much to add? ";
        cin >> add;
        currentWater = currentWater + add;
    }
    cout << "Glass is full with water: " << currentWater << "ml" << endl;
    
    return 0;
}


//Program 13 -- ATM PIN retry system

#include <iostream>
using namespace std;

int main() {
    int correctPin = 1234;
    int enteredPin;
    int attempts = 0;

    while (attempts < 3) {
        cout << "Enter your ATM PIN: ";
        cin >> enteredPin;

        if (enteredPin == correctPin) {
            cout << "Access Granted!\n";
            break;
        } else {
            cout << "Wrong PIN!\n";
            attempts++;
        }
    }

    if (attempts == 3) {
        cout << "Card Blocked! Too many wrong attempts.\n";
    }

    return 0;
}

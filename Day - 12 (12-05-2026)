// 1  Recursion Function

#include <iostream>
using namespace std;

void printNumber(int n) {
    
    if(n > 5) {
        return;
    }
    cout << n << " ";
    printNumber(n + 1);
}
int main()
{
    printNumber(1);
}

// 2  Factorial of a printNumber

#include <iostream>
using namespace std;

int main(){
    int num, fact = 1;

    cout << "Enter a number: ";
    cin >> num;

    for(int i = 1; i <= num; i++)
    {
        fact = fact * i;
    }

    cout << "Factorial = " << fact;

    return 0;
}

or

#include <iostream>
using namespace std;

int factorial(int n){    
    
    if(n == 0 || n == 1){
        return 1;
    }
    return n * factorial(n - 1);   
}

int main() {
    cout << factorial(5);
}

// 3 Fibonacci through Recursion

#include <iostream>
using namespace std;

int fibo(int n) {
    // base condition
    if(n == 0) {
        return 0;
    }
    if(n == 1) {
        return 1;
    }
    // logic
    return fibo(n - 1) + fibo(n - 2);
}
int main() {
    cout << fibo(4);
}



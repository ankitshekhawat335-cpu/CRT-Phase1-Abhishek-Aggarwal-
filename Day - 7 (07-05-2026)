// Program -3 -- protected Access Specifier

#include <iostream>
using namespace std;

class Parent {
    protected:
    int secretCode = 2345;
};

class Child : Parent{
    public:
    void accessLocker(){
    cout << secretCode;    
    }
};

int main() {
    Child obj1;
    obj1.accessLocker();
}



// 7.1 -- public

#include <iostream>
using namespace std;

class publicPark{
public:
    void enter(){
        cout << "Anyone can  enter...";
    }
};
int main(){
    publicPark p;
    p.enter();
}

// 7.2 -- private

#include <iostream>
using namespace std;

class privateRoom{
private:
    void secret(){
        cout << "This is a private room...";
    }

public:
    void access(){
        secret();  
    }
};

int main(){
    privateRoom r;
    r.access();  
}

// 7.3 -- protected

#include <iostream>
using namespace std;

class Parent{
protected:
    void show(){
        cout << "This is protected area...";
    }
};

class Child : public Parent{
public:
    void access(){
        show();   
    }
};

int main(){
    Child c;
    c.access();
}

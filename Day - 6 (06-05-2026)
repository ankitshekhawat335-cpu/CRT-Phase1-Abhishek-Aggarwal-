// Program -2 -- discount 

#include <iostream>
using namespace std;

int discount(int amount, int discountamount){
    discountamount = (amount * discountamount)/100;
    return amount - discountamount;
}
int main() {
    int n;
    int discountPercentage;
    cin >> n;
    cin >> discountPercentage;
    cout << discount(n, discountPercentage);
}



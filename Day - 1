//Program 6
//Alphabet Case Checker

#include <iostream>
using namespace std;

int main() {
    char ch;
    cin >> ch;

    if (ch >= 'A' && ch <= 'Z')
        cout << "Uppercase";
    else if (ch >= 'a' && ch <= 'z')
        cout << "Lowercase";
    else
        cout << "Not alphabet";

    return 0;
}


//Program 7
//Age Group Classifier


#include <iostream>
using namespace std;

int main() {
    int age;
    cin >> age;

    if (age < 13)
        cout << "Child";
    else if (age < 20)
        cout << "Teenager";
    else if (age < 60)
        cout << "Adult";
    else
        cout << "Senior";

    return 0;
}


//Program 8
//Area of shapes

#include <iostream>
using namespace std;

int main() {
    int choice;
    cout << "1.Circle  2.Rectangle  3.Triangle\n";
    cin >> choice;

    if (choice == 1) {
        float r;
        cin >> r;
        cout << 3.14 * r * r;
    }
    else if (choice == 2) {
        float l, b;
        cin >> l >> b;
        cout << l * b;
    }
    else if (choice == 3) {
        float base, height;
        cin >> base >> height;
        cout << 0.5 * base * height;
    }
    else {
        cout << "Invalid choice";
    }

    return 0;
}



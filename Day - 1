}


//Program 4 
//swapping of two variables
#include <iostream>
using namespace std;

int main() {
    int a,b;
    cin >> a >> b;
    
    //logic to swap two variables
    int temp = a;
    a = b;
    b = temp;
    // printing the values
    cout << a << "\n" << b << endl;
    return 0;
}



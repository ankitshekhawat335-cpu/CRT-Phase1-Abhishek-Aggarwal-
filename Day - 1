//Problem 1
//Problem to convert celcius to Fahrenheit

#include <iostream>
using namespace std;

int main() {
    double celcius;
    double Fahrenheit;
    cin>>celcius;
    
   Fahrenheit = (celcius * 9.0 / 5.0 ) + 32;
    cout << Fahrenheit << endl;
    return 0;
}



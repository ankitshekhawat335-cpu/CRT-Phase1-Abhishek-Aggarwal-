// Program 5 Function overloading

 #include <iostream>
 using namespace std;
 
 int add(int a, int b){
     return a+b;
 }
  double add(double a, double b){
     return a+b;
 }
 
  int add(int a, int b, int c){
     return a+b+c;
 }
 
 float add(float a, float b, float c, float d){
     return a+b+c+d;
 }
 
 int main() {
     cout << add(5,3) << "\n";
     cout << add(3.6,4.2) << "\n";
     cout << add(5,3,2) << "\n";
     cout << add(5.2,6.3,1.2,3.5) << "\n";
 }
